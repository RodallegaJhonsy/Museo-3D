{
  "buildCommand": "echo 'Static files ready for deployment'",
  "outputDirectory": ".",
  "public": true,
  "functions": {},
  "routes": [
    {
      "src": "^/(?!.*\\.).*$",
      "destination": "/Index.html"
    }
  ],
  "rewrites": [
    {
      "source": "/(?!.*\\.).*",
      "destination": "/Index.html"
    }
  ]
}
